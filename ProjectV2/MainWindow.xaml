<Window x:Class="ProjectV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectV2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <TabControl TabStripPlacement="Top">
        <TabItem Tag="Defense">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Type Defense" FontSize="16" Foreground="Black" Margin="0,0,0,0"/>
                </StackPanel>
            </TabItem.Header>
            <Grid Loaded="Grid_Loaded">
                <Button x:Name="BtnPyro" Content="Pyro" HorizontalAlignment="Left" Margin="30,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE81212" BorderBrush="#FFC10909" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnAqua" Content="Aqua" HorizontalAlignment="Left" Margin="150,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0890E8" BorderBrush="#FF0872B7" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnFlora" Content="Flora" HorizontalAlignment="Left" Margin="30,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF3BE40D" BorderBrush="#FF2FC108" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnTerra" Content="Terra" HorizontalAlignment="Left" Margin="150,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" BorderBrush="#FFB35E07" Background="#FFDA730A" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnVephyr" Content="Vephyr" HorizontalAlignment="Left" Margin="30,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE0F9F5" BorderBrush="#FFBFDCD7" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnGlacial" Content="Glacial" HorizontalAlignment="Left" Margin="150,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF8DE8F3" BorderBrush="#FF78CED8" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnElectro" Content="Electro" HorizontalAlignment="Left" Margin="30,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF7E200" BorderBrush="#FFE6B303" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnMetal" Content="Metal" HorizontalAlignment="Left" Margin="150,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Background="#FF7E86B3" BorderBrush="#FF4F5473" Click="Btn_Click"/>
                <Button x:Name="BtnNoxious" Content="Noxious" HorizontalAlignment="Left" Margin="30,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnLumen" Content="Lumen" HorizontalAlignment="Left" Margin="150,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF8FBC1" BorderBrush="#FFF0F3AB" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnSpirit" Content="Spirit" HorizontalAlignment="Left" Margin="30,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFA93AB7" BorderBrush="#FF802C8A" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnVita" Content="Vita" HorizontalAlignment="Left" Margin="150,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0AFDAA" BorderBrush="#FF07D28D" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnType1" Content="Type" Margin="30,311,684,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType1_Click" Height="32"/>
                <Button x:Name="BtnType2" Content="Type" HorizontalAlignment="Left" Margin="126,311,0,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType2_Click" Height="32" Width="86"/>
                <Button x:Name="BtnType3" Content="Type" Margin="217,311,498,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType3_Click" Height="32"/>
                <Button x:Name="BtnCalculate" Content="Calculate" HorizontalAlignment="Left" Margin="300,32,0,0" VerticalAlignment="Top" Click="BtnCalculate_Click"/>
                <ListBox x:Name="TxtResults" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="420,10,36,10" BorderBrush="Black" Background="#FFECECEC" Loaded="TxtResults_Loaded"/>

            </Grid>

        </TabItem>
        <TabItem Tag="Offense">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="The ARCAT" FontSize="16" Foreground="Black" Margin="0,0,0,0"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="239*"/>
                    <ColumnDefinition Width="561*"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="ArcatLst" Margin="10,41,3,0" Background="#FFECECEC" Height="208" VerticalAlignment="Top"/>
                <Image x:Name="ImgArviva" HorizontalAlignment="Left" Height="169" Margin="17,23,0,0" VerticalAlignment="Top" Width="169" Grid.Column="1"/>
                <Button x:Name="BtnBack" Content="&lt;&lt;&lt;" HorizontalAlignment="Left" Margin="202,23,0,0" VerticalAlignment="Top" Height="44" Width="50" Background="#FF673AB7" Grid.Column="1" Click="BtnBack_Click"/>
                <Button x:Name="BtnForward" Content="&gt;&gt;" HorizontalAlignment="Left" Margin="488,23,0,0" VerticalAlignment="Top" Height="44" Width="50" Grid.Column="1" Click="BtnForward_Click"/>
                <TextBlock x:Name="TxBlArvivaName" HorizontalAlignment="Left" Margin="285,23,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="44" Width="167" Background="#FFECECEC" Grid.Column="1"/>
                <TextBlock x:Name="TxBlArvivaCategory" HorizontalAlignment="Left" Margin="302,72,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="32" Width="133" Background="#FFECECEC" Grid.Column="1"/>
                <TextBlock x:Name="Stat_Hp" HorizontalAlignment="Left" Margin="285,121,0,0" TextWrapping="Wrap" Text="HP" VerticalAlignment="Top" Background="#FFECECEC" Height="26" Width="70" Grid.Column="1"/>
                <TextBlock x:Name="Stat_Speed" HorizontalAlignment="Left" Margin="382,121,0,0" TextWrapping="Wrap" Text="SPD" VerticalAlignment="Top" Background="#FFECECEC" Height="26" Width="70" Grid.Column="1"/>
                <TextBlock x:Name="Stat_Atk" HorizontalAlignment="Left" Margin="285,156,0,0" TextWrapping="Wrap" Text="ATK" VerticalAlignment="Top" Background="#FFECECEC" Height="26" Width="70" Grid.Column="1"/>
                <TextBlock x:Name="Stat_MAtk" HorizontalAlignment="Left" Margin="382,156,0,0" TextWrapping="Wrap" Text="MATK" VerticalAlignment="Top" Background="#FFECECEC" Height="26" Width="70" Grid.Column="1"/>
                <TextBlock x:Name="Stat_Def" HorizontalAlignment="Left" Margin="285,193,0,0" TextWrapping="Wrap" Text="DEF" VerticalAlignment="Top" Background="#FFECECEC" Height="26" Width="70" Grid.Column="1"/>
                <TextBlock x:Name="Stat_MDef" HorizontalAlignment="Left" Margin="382,193,0,0" TextWrapping="Wrap" Text="MDEF" VerticalAlignment="Top" Background="#FFECECEC" Height="26" Width="70" Grid.Column="1"/>
                <TextBlock x:Name="ArcatEntry" HorizontalAlignment="Left" Margin="101,255,0,0" TextWrapping="Wrap" Text="Entry:" VerticalAlignment="Top" Background="#FFECECEC" Height="121" Width="450" Grid.Column="1"/>
                <ComboBox HorizontalAlignment="Left" Margin="10,6,0,0" VerticalAlignment="Top" Width="120" Background="#FFECECEC"/>
                <Button x:Name="BtnData" Content="Data" HorizontalAlignment="Left" Margin="2,216,0,0" VerticalAlignment="Top" Height="33" Width="91" Background="#FF673AB7" Grid.Column="1" Click="BtnData_Click"/>
                <TextBox x:Name="UserName" HorizontalAlignment="Left" Margin="10,276,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Text="Username" GotFocus="UserName_GotFocus" LostFocus="UserName_LostFocus"/>
                <TextBox x:Name="UserPassword" HorizontalAlignment="Left" Margin="10,316,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Text="Password" GotFocus="UserPassword_GotFocus" LostFocus="UserPassword_LostFocus"/>
                <Button x:Name="BtnLogin" Content="Login" HorizontalAlignment="Left" Margin="145,316,0,0" VerticalAlignment="Top" Height="28" Width="91" Background="#FF673AB7"/>
                <Button x:Name="BtnNewTeam" Content="New Team" HorizontalAlignment="Left" Margin="145,6,0,0" VerticalAlignment="Top" Height="25" Width="84" FontSize="10"/>
            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Hazards" FontSize="16" Foreground="Black" Margin="0,0,0,0"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Button x:Name="SpikesMain" Content="Spikes" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="139" Width="150" BorderBrush="Black" Foreground="Black" FontSize="36" Click="SpikesMain_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/spikes.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="TendrilsMain" HorizontalAlignment="Right" Margin="0,10,10,0" VerticalAlignment="Top" Height="139" Width="150" BorderBrush="Black" Content="Tendrils" Foreground="Black" FontSize="34" Click="TendrilsMain_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Vines.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="WeatherMain" Content="Weather" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="139" Width="150" BorderBrush="Black" Foreground="Black" FontSize="30" Click="WeatherMain_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Sun.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnTerraSpikes" Content="Button" HorizontalAlignment="Left" Margin="10,170,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnTerraSpikes_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/spikes.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnGlacialSpikes" Content="Button" HorizontalAlignment="Left" Margin="10,264,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnGlacialSpikes_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Icecubes.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnMetalSpikes" Content="Button" HorizontalAlignment="Left" Margin="104,170,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnMetalSpikes_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/metalspikes.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnNoxiousSpikes" Content="Button" HorizontalAlignment="Left" Margin="104,264,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnNoxiousSpikes_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/toxicspikes.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnPyroWeather" Content="Button" HorizontalAlignment="Left" Margin="10,170,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnPyroWeather_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Sun.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnVephyrWeather" Content="Button" HorizontalAlignment="Left" Margin="10,264,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnVephyrWeather_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Wind.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnAquaWeather" Content="Button" HorizontalAlignment="Left" Margin="104,170,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnAquaWeather_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Rain.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnElectroWeather" Content="Button" HorizontalAlignment="Left" Margin="104,264,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnElectroWeather_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/StormCloud.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnFloraTendrils" Content="Button" HorizontalAlignment="Left" Margin="10,170,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnFloraTendrils_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Vines.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnSpiritTendrils" Content="Button" HorizontalAlignment="Left" Margin="10,264,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnSpiritTendrils_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/graspingsouls.jpg"/>
                    </Button.Background>
                </Button>
                <Button
                Margin="104,170,0,0" Width="89" VerticalAlignment="Top" x:Name="BtnLumenTendrils" Height="89" HorizontalAlignment="Left" Foreground="{x:Null}" Content="Button" Click="BtnLumenTendrils_Click">
                    <Button.Background
                >
                        <ImageBrush
                ImageSource="/content/vinelights.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="BtnVitaTendrils" Content="Button" HorizontalAlignment="Left" Margin="104,264,0,0" VerticalAlignment="Top" Height="89" Width="89" Foreground="{x:Null}" Click="BtnVitaTendrils_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/mycelium.jpg"/>
                    </Button.Background>
                </Button>
                <Image x:Name="ImgHazard" HorizontalAlignment="Left" Height="144" Margin="212,193,0,0" VerticalAlignment="Top" Width="144"/>
                <TextBlock x:Name="TxBlHazards" HorizontalAlignment="Left" Margin="374,193,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="173" Width="405"/>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
