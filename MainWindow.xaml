<Window x:Class="ProjectV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectV2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <TabControl TabStripPlacement="Top">
        <TabItem Tag="Defense">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Type Defense" FontSize="16" Foreground="Black" Margin="0,0,0,0"/>
                </StackPanel>
            </TabItem.Header>
            <Grid Loaded="Grid_Loaded">
                <Button x:Name="BtnPyro" Content="Pyro" HorizontalAlignment="Left" Margin="30,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE81212" BorderBrush="#FFC10909" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnAqua" Content="Aqua" HorizontalAlignment="Left" Margin="150,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0890E8" BorderBrush="#FF0872B7" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnFlora" Content="Flora" HorizontalAlignment="Left" Margin="30,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF3BE40D" BorderBrush="#FF2FC108" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnTerra" Content="Terra" HorizontalAlignment="Left" Margin="150,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" BorderBrush="#FFB35E07" Background="#FFDA730A" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnVephyr" Content="Vephyr" HorizontalAlignment="Left" Margin="30,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE0F9F5" BorderBrush="#FFBFDCD7" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnGlacial" Content="Glacial" HorizontalAlignment="Left" Margin="150,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF8DE8F3" BorderBrush="#FF78CED8" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnElectro" Content="Electro" HorizontalAlignment="Left" Margin="30,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF7E200" BorderBrush="#FFE6B303" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnMetal" Content="Metal" HorizontalAlignment="Left" Margin="150,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Background="#FF7E86B3" BorderBrush="#FF4F5473" Click="Btn_Click"/>
                <Button x:Name="BtnNoxious" Content="Noxious" HorizontalAlignment="Left" Margin="30,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnLumen" Content="Lumen" HorizontalAlignment="Left" Margin="150,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF8FBC1" BorderBrush="#FFF0F3AB" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnSpirit" Content="Spirit" HorizontalAlignment="Left" Margin="30,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFA93AB7" BorderBrush="#FF802C8A" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnVita" Content="Vita" HorizontalAlignment="Left" Margin="150,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0AFDAA" BorderBrush="#FF07D28D" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnType1" Content="Type" Margin="30,311,684,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType1_Click" Height="32"/>
                <Button x:Name="BtnType2" Content="Type" HorizontalAlignment="Left" Margin="126,311,0,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType2_Click" Height="32" Width="86"/>
                <Button x:Name="BtnType3" Content="Type" Margin="217,311,498,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType3_Click" Height="32"/>
                <Button x:Name="BtnCalculate" Content="Calculate" HorizontalAlignment="Left" Margin="300,32,0,0" VerticalAlignment="Top" Click="BtnCalculate_Click"/>
                <ListBox x:Name="TxtResults" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="420,10,36,10" BorderBrush="Black" Background="#FFECECEC" Loaded="TxtResults_Loaded"/>

            </Grid>

        </TabItem>
        <TabItem Tag="Offense">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Type Offense" FontSize="16" Foreground="Black" Margin="0,0,0,0"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Button x:Name="BtnPyro2" Content="Pyro" HorizontalAlignment="Left" Margin="30,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE81212" BorderBrush="#FFC10909" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnAqua2" Content="Aqua" HorizontalAlignment="Left" Margin="150,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0890E8" BorderBrush="#FF0872B7" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnFlora2" Content="Flora" HorizontalAlignment="Left" Margin="30,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF3BE40D" BorderBrush="#FF2FC108" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnTerra2" Content="Terra" HorizontalAlignment="Left" Margin="150,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" BorderBrush="#FFB35E07" Background="#FFDA730A" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnVephyr2" Content="Vephyr" HorizontalAlignment="Left" Margin="30,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE0F9F5" BorderBrush="#FFBFDCD7" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnGlacial2" Content="Glacial" HorizontalAlignment="Left" Margin="150,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF8DE8F3" BorderBrush="#FF78CED8" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnElectro2" Content="Electro" HorizontalAlignment="Left" Margin="30,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF7E200" BorderBrush="#FFE6B303" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnMetal2" Content="Metal" HorizontalAlignment="Left" Margin="150,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Background="#FF7E86B3" BorderBrush="#FF4F5473" Click="Btn_Click"/>
                <Button x:Name="BtnNoxious2" Content="Noxious" HorizontalAlignment="Left" Margin="30,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnLumen2" Content="Lumen" HorizontalAlignment="Left" Margin="150,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF8FBC1" BorderBrush="#FFF0F3AB" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnSpirit2" Content="Spirit" HorizontalAlignment="Left" Margin="30,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFA93AB7" BorderBrush="#FF802C8A" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnVita2" Content="Vita" HorizontalAlignment="Left" Margin="150,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0AFDAA" BorderBrush="#FF07D28D" Foreground="Black" Click="Btn_Click"/>
                <Button x:Name="BtnType1_2" Content="Type" Margin="30,311,684,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType1_Click" Height="32"/>
                <Button x:Name="BtnType2_2" Content="Type" HorizontalAlignment="Left" Margin="126,311,0,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType2_Click" Height="32" Width="86"/>
                <Button x:Name="BtnType3_2" Content="Type" Margin="217,311,498,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType3_Click" Height="32"/>
                <ListBox x:Name="TxtOffense" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="420,10,36,10" BorderBrush="Black" Background="#FFECECEC" Loaded="TxtResults_Loaded"/>
                <Button x:Name="BtnCalculateOffense" Content="Calculate" HorizontalAlignment="Left" Margin="280,242,0,0" VerticalAlignment="Top" Click="BtnCalculateOffense_Click"/>

            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Hazards" FontSize="16" Foreground="Black" Margin="0,0,0,0"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Frame x:Name="TypeChartFrame" NavigationUIVisibility="Hidden"/>
                <Button x:Name="SpikesMain" Content="Button" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="139" Width="150" BorderBrush="Black" Foreground="Black">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/spikes.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="TendrilsMain" HorizontalAlignment="Right" Margin="0,10,10,0" VerticalAlignment="Top" Height="139" Width="150" BorderBrush="Black" Content="Button" Foreground="Black">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Vines.jpg"/>
                    </Button.Background>
                </Button>
                <Button x:Name="WeatherMain" Content="Button" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="139" Width="150" BorderBrush="Black" Foreground="Black">
                    <Button.Background>
                        <ImageBrush ImageSource="/content/Sun.jpg"/>
                    </Button.Background>               </Button>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
