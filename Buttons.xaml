<UserControl x:Class="ProjectV2.Buttons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:uc="clr-namespace:ProjectV2"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProjectV2"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Button x:Name="BtnPyro" Content="Pyro" HorizontalAlignment="Left" Margin="30,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE81212" BorderBrush="#FFC10909" Foreground="Black" Click="BtnPyro_Click"/>
        <Button x:Name="BtnAqua" Content="Aqua" HorizontalAlignment="Left" Margin="150,33,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0890E8" BorderBrush="#FF0872B7" Foreground="Black" Click="BtnAqua_Click"/>
        <Button x:Name="BtnFlora" Content="Flora" HorizontalAlignment="Left" Margin="30,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF3BE40D" BorderBrush="#FF2FC108" Foreground="Black" Click="BtnFlora_Click"/>
        <Button x:Name="BtnTerra" Content="Terra" HorizontalAlignment="Left" Margin="150,78,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" BorderBrush="#FFB35E07" Background="#FFDA730A" Foreground="Black" Click="BtnTerra_Click"/>
        <Button x:Name="BtnVephyr" Content="Vephyr" HorizontalAlignment="Left" Margin="30,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFE0F9F5" BorderBrush="#FFBFDCD7" Foreground="Black" Click="BtnVephyr_Click"/>
        <Button x:Name="BtnGlacial" Content="Glacial" HorizontalAlignment="Left" Margin="150,125,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF8DE8F3" BorderBrush="#FF78CED8" Foreground="Black" Click="BtnGlacial_Click"/>
        <Button x:Name="BtnElectro" Content="Electro" HorizontalAlignment="Left" Margin="30,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF7E200" BorderBrush="#FFE6B303" Foreground="Black" Click="BtnElectro_Click"/>
        <Button x:Name="BtnMetal" Content="Metal" HorizontalAlignment="Left" Margin="150,218,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Background="#FF7E86B3" BorderBrush="#FF4F5473" Click="BtnMetal_Click"/>
        <Button x:Name="BtnNoxious" Content="Noxious" HorizontalAlignment="Left" Margin="30,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Foreground="Black" Click="BtnNoxious_Click"/>
        <Button x:Name="BtnLumen" Content="Lumen" HorizontalAlignment="Left" Margin="150,171,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFF8FBC1" BorderBrush="#FFF0F3AB" Foreground="Black" Click="BtnLumen_Click"/>
        <Button x:Name="BtnSpirit" Content="Spirit" HorizontalAlignment="Left" Margin="30,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FFA93AB7" BorderBrush="#FF802C8A" Foreground="Black" Click="BtnSpirit_Click"/>
        <Button x:Name="BtnVita" Content="Vita" HorizontalAlignment="Left" Margin="150,264,0,0" VerticalAlignment="Top" Width="86" Height="30" FontSize="14" Background="#FF0AFDAA" BorderBrush="#FF07D28D" Foreground="Black" Click="BtnVita_Click"/>
        <Button x:Name="BtnType1" Content="Type" Margin="30,311,684,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType1_Click" Height="32"/>
        <Button x:Name="BtnType2" Content="Type" HorizontalAlignment="Left" Margin="126,311,0,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType2_Click" Height="32" Width="86"/>
        <Button x:Name="BtnType3" Content="Type" Margin="217,311,481,0" VerticalAlignment="Top" Foreground="Black" BorderBrush="White" Background="White" Click="BtnType3_Click" Height="32"/>
    </Grid>
</UserControl>
